rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Utility functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Check if the user's UID exists in the roles_admin collection
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // User profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // Role lookups
    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      // Allow bootstrap: Anyone can promote themselves to admin for development
      allow write: if isSignedIn() && (isAdmin() || request.auth.uid == userId);
    }

    // Menu Catalog
    match /menu_items/{itemId} {
      // Allow any signed-in user to view the menu
      allow get, list: if isSignedIn();
      // Only admins can modify the menu
      allow create, update, delete: if isAdmin();
    }

    // Orders
    match /orders/{orderId} {
      // Explicitly allow both single doc get and collection list for all staff
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        // Only allow updating pending orders, or allow admins full access
        (resource.data.status == 'pending') || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Daily Reports
    match /daily_reports/{reportId} {
      // Allow viewing stats to all signed in users
      allow get, list: if isSignedIn();
      // Allow admins (or the system via admin-triggered actions) to write reports
      allow write: if isSignedIn(); // Broaden for development so lazy aggregation works
    }
  }
}