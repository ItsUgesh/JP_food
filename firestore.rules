rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Utility functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // User profiles - allow owner to manage their own profile completely
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // Role lookups - allow admins to manage, and allow users to see their own status.
    // Includes a bootstrap allowance for self-promotion if signed in.
    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // Menu Catalog - staff can read, only admins can write
    match /menu_items/{itemId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Orders - standard staff/admin POS flow
    match /orders/{orderId} {
      allow read, create: if isSignedIn();
      allow update: if isSignedIn() && (isAdmin() || resource.data.status == 'pending');
      allow delete: if isAdmin();
    }

    // Daily Reports - aggregation and analytics
    match /daily_reports/{reportId} {
      allow read, write: if isSignedIn();
    }
  }
}