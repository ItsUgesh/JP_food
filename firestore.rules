rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Utility functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // User profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // Role lookups
    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      // Allow bootstrap: Anyone can promote themselves to admin for development
      allow write: if isSignedIn() && (isAdmin() || request.auth.uid == userId);
    }

    // Menu Catalog
    match /menu_items/{itemId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // Orders
    match /orders/{orderId} {
      // Both staff and admins can view and create orders
      allow get, list, create: if isSignedIn();
      
      // Updates allowed for pending orders (all staff) or any order (admins)
      allow update: if isSignedIn() && (
        (resource.data.status == 'pending') || isAdmin()
      );
      
      // Only admins can delete orders
      allow delete: if isAdmin();
    }

    // Daily Reports
    match /daily_reports/{reportId} {
      allow get, list: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}