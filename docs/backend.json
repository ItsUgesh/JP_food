
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user account with specific roles for accessing the POS system.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "name": {
          "type": "string",
          "description": "The full name of the user."
        },
        "email": {
          "type": "string",
          "description": "The email address of the user.",
          "format": "email"
        },
        "role": {
          "type": "string",
          "description": "The role of the user within the system (e.g., \"admin\", \"staff\")."
        }
      },
      "required": [
        "id",
        "name",
        "email",
        "role"
      ]
    },
    "MenuItem": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "MenuItem",
      "type": "object",
      "description": "Represents a single item available on the cafe's menu.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the MenuItem entity."
        },
        "name": {
          "type": "string",
          "description": "The name of the menu item."
        },
        "price": {
          "type": "number",
          "description": "The price of the menu item."
        },
        "category": {
          "type": "string",
          "description": "The category the menu item belongs to (e.g., Drinks, Snacks, Meals)."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp indicating when the menu item was created.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "name",
        "price",
        "category",
        "createdAt"
      ]
    },
    "Order": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Order",
      "type": "object",
      "description": "Represents a customer order placed in the cafe, linking to its individual order items.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Order entity."
        },
        "tableNumber": {
          "type": "string",
          "description": "The table number associated with the order."
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/backend/entities/OrderItem"
          }
        },
        "total": {
          "type": "number",
          "description": "The total calculated price of all items in the order."
        },
        "status": {
          "type": "string",
          "description": "The current status of the order.",
          "enum": ["pending", "paid"]
        },
        "paymentMethod": {
          "type": "string",
          "description": "The method used for payment.",
          "enum": ["cash", "esewa"]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "paidAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "tableNumber",
        "items",
        "total",
        "status",
        "createdAt"
      ]
    },
    "OrderItem": {
      "title": "OrderItem",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "qty": { "type": "number" }
      }
    },
    "DailyReport": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "DailyReport",
      "type": "object",
      "description": "Structured daily revenue report for analytics.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Date ID in format YYYY-MM-DD (Nepal Time)."
        },
        "date": {
          "type": "string",
          "format": "date"
        },
        "totalRevenue": {
          "type": "number"
        },
        "cashRevenue": {
          "type": "number"
        },
        "esewaRevenue": {
          "type": "number"
        },
        "numberOfOrders": {
          "type": "number"
        }
      },
      "required": ["id", "date", "totalRevenue", "cashRevenue", "esewaRevenue", "numberOfOrders"]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "Stores individual user profiles."
        }
      },
      {
        "path": "/roles_admin/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "A lookup collection for admin roles."
        }
      },
      {
        "path": "/menu_items/{menuItemId}",
        "definition": {
          "entityName": "MenuItem",
          "schema": {
            "$ref": "#/backend/entities/MenuItem"
          },
          "description": "Stores menu items."
        }
      },
      {
        "path": "/orders/{orderId}",
        "definition": {
          "entityName": "Order",
          "schema": {
            "$ref": "#/backend/entities/Order"
          },
          "description": "Stores customer orders."
        }
      },
      {
        "path": "/daily_reports/{reportId}",
        "definition": {
          "entityName": "DailyReport",
          "schema": {
            "$ref": "#/backend/entities/DailyReport"
          },
          "description": "Stores aggregated daily reports."
        }
      }
    ]
  }
}
